  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prepare-pages.mjs",
    "preview": "vite preview",
    "deploy:pages": "npm run build && node scripts/publish-gh-pages.mjs",
    "perf:audit:preview": "npm run build && node scripts/perf/run-audit.mjs preview",
    "perf:audit:pages": "node scripts/perf/run-audit.mjs pages",
